
# ---- Supabase (required) -----------------------------------
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Server-only — used for articles import/setup (bypasses RLS). Never expose.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Direct Postgres access for scripts/migrations (scripts/setup-articles.mjs
# and applying supabase/migrations/*.sql). Any ONE of these forms works:
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_DB_PASSWORD=
DATABASE_URL=

# ---- Content import ----------------------------------------
# Protects POST /api/articles/import — any random string
ARTICLES_IMPORT_SECRET=

# ---- AI: single-model features -----------------------------
# Powers TL;DR generation, related papers, and the guest paper chat.
# Also enables the "Claude" provider for the research agent.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# AI RESEARCH AGENT (/research) — LLM providers
# Set at least ONE key below (ANTHROPIC_API_KEY above also counts).
# Providers without a key are hidden from the UI automatically.
# ============================================================
CEREBRAS_API_KEY=                # https://cloud.cerebras.ai
OPENROUTER_API_KEY=              # https://openrouter.ai/keys
DEEPSEEK_API_KEY=                # https://platform.deepseek.com
GEMINI_API_KEY=                  # https://aistudio.google.com/apikey

# Optional agent behavior overrides -------------------------
# Which provider is preselected: cerebras|openrouter|deepseek|gemini|anthropic
AGENT_DEFAULT_PROVIDER=
# Per-provider model overrides (defaults shown)
AGENT_CEREBRAS_MODEL=            # default: gpt-oss-120b
AGENT_OPENROUTER_MODEL=          # default: openai/gpt-oss-120b
AGENT_DEEPSEEK_MODEL=            # default: deepseek-chat
AGENT_GEMINI_MODEL=              # default: gemini-2.5-flash
AGENT_ANTHROPIC_MODEL=           # default: claude-opus-4-8 (claude-haiku-4-5 = cheap/fast)
# Comma-separated tool allowlist override (advanced; see lib/agent/tools.ts)
AGENT_ENABLED_TOOLS=
# Wikipedia tools are on by default; set to false to disable
AGENT_ENABLE_WIKIPEDIA=true

# ============================================================
# Scientific data sources (agent tools)
# ============================================================
# Contact email sent to OpenAlex/Crossref/PubMed "polite pools" (mailto +
# User-Agent). Strongly recommended — better rate limits, and some APIs
# deprioritize anonymous callers.
CONTACT_EMAIL=you@example.com

# OpenAlex — REQUIRED for openalex_* tools since Feb 2026 (anonymous callers
# get a small grace-credit pool, then fail). Free key: https://openalex.org
OPENALEX_API_KEY=

# CORE — required for core_* tools (they are hidden from the agent when this
# is unset). Free key: https://core.ac.uk/services/api
CORE_API_KEY=

# Semantic Scholar — optional but recommended; the anonymous pool rate-limits
# heavily (the agent falls back to Crossref when that happens).
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# NCBI/PubMed — optional; raises the rate limit from 3/s to 10/s.
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# Crossref, arXiv, Europe PMC, Wikipedia: no keys required.

# ---- Misc ---------------------------------------------------
# Public URL of this app — used for OpenRouter attribution headers
APP_URL=http://localhost:3000
